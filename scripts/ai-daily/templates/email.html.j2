<!doctype html>
<html lang="nb">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AI Daily — {{ payload.date }}</title>
</head>
<body style="margin:0;padding:0;background:#f4f1ec;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;color:#1a1a1a;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f1ec;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;background:#fdfdfb;border:1px solid #d8d4cc;">
          <tr>
            <td style="padding:32px 32px 16px;border-bottom:1px solid #d8d4cc;">
              <div style="font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:#5a5a5a;font-weight:600;">AI Daily</div>
              <div style="font-size:22px;font-weight:700;margin-top:4px;">{{ payload.date }}</div>
            </td>
          </tr>

          {% if payload.take %}
          <tr>
            <td style="padding:24px 32px 8px;">
              <div style="background:#f4f1ec;border-left:3px solid #6b3d2e;padding:14px 16px;font-size:15px;line-height:1.55;color:#1a1a1a;">
                <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#5a5a5a;font-weight:600;margin-bottom:6px;">Dagens take</div>
                {{ payload.take }}
              </div>
            </td>
          </tr>
          {% endif %}

          {% if teasers %}
          <tr>
            <td style="padding:16px 32px 8px;">
              <div style="font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:#5a5a5a;font-weight:600;margin-bottom:10px;">Tre å merke seg</div>
              <ul style="margin:0;padding:0 0 0 18px;font-size:14px;line-height:1.5;color:#1a1a1a;">
                {% for t in teasers %}
                <li style="margin-bottom:6px;">
                  <strong>{{ t.title }}</strong>
                  <span style="color:#5a5a5a;">— {{ t.source }}{% if t.region_label %} · {{ t.region_label }}{% endif %}</span>
                </li>
                {% endfor %}
              </ul>
            </td>
          </tr>
          {% endif %}

          <tr>
            <td align="center" style="padding:24px 32px 32px;">
              <a href="{{ web_url }}" style="display:inline-block;background:#6b3d2e;color:#fdfdfb;text-decoration:none;font-weight:600;padding:12px 24px;font-size:15px;border-radius:2px;">Les hele utgaven</a>
            </td>
          </tr>

          <tr>
            <td style="padding:16px 32px 24px;border-top:1px solid #d8d4cc;font-size:12px;color:#5a5a5a;">
              Kuratert av Claude Sonnet 4.6. Generert {{ generated_at }}.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
